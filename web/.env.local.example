# Copy to .env.local and adjust.
# Base URL of the FastAPI admin backend (admin_api.py)
NEXT_PUBLIC_API_BASE=http://localhost:8002
# Pilot-only bearer token (matches ADMIN_API_TOKEN on the backend).
# In production this is replaced by a real login/JWT flow — do NOT ship a static token.
NEXT_PUBLIC_ADMIN_TOKEN=dev-token
