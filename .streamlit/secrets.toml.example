# Streamlit Cloud Secrets 설정 예시
# Streamlit Cloud 대시보드의 App settings > Secrets 에 아래 내용을 붙여넣으세요.
# 이 파일 자체는 git에 포함되지만, 실제 secrets.toml 파일은 .gitignore로 제외됩니다.

# PostgreSQL (Supabase 등)
DATABASE_URL = "postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Anthropic API (PDF OCR 자동 입력 기능)
ANTHROPIC_API_KEY = "sk-ant-api03-..."

# 이메일 (선택 - 발송 기능 사용 시)
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = "sales@k-maris.com"
SMTP_PASSWORD = "your_app_password"
SMTP_FROM = "K-MARIS Sales <sales@k-maris.com>"
