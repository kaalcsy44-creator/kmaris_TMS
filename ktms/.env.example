# KTMS Environment Variables
# Copy this file to .env and fill in the values

# Database (default: SQLite in ./data/ktms.db)
DATABASE_URL=sqlite:///./data/ktms.db

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sales@k-maris.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=K-MARIS Sales <sales@k-maris.com>

# Security
SECRET_KEY=change-me-to-a-random-secret-key

# Company prefix for document numbers
COMPANY_PREFIX=KMS
