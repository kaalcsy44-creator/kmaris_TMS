# KTMS Environment Variables
# Copy this file to .env and fill in the values

# Database (default: SQLite in ./data/ktms.db)
DATABASE_URL=sqlite:///./data/ktms.db

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sales@k-maris.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=K-MARIS Sales <sales@k-maris.com>

# Security
SECRET_KEY=change-me-to-a-random-secret-key

# Company prefix for document numbers
COMPANY_PREFIX=KMS

# Google Sheets sync (tracking_gas.js 연동)
# 스프레드시트 ID: URL의 /d/XXXX/ 부분
GOOGLE_SHEET_ID=1YwpCt1jJNkQVpng2q2B9CmwvaksCxkXpadIuAVyXWmk
# 서비스 계정 키 파일 경로 (둘 중 하나만 설정)
GOOGLE_SA_KEY_FILE=./config/google_sa_key.json
# 또는 JSON 내용 전체를 한 줄 문자열로 (Streamlit Cloud 등 파일 사용 불가 환경)
# GOOGLE_SA_KEY_JSON={"type":"service_account","project_id":"...","private_key_id":"...",...}
